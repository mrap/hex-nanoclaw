# hex-nanoclaw environment configuration
# Copy to .env and fill in values

# Anthropic API key (required for Claude Agent SDK)
ANTHROPIC_API_KEY=your-key-here

# Hindsight URL (for semantic memory search inside containers)
# Must use host.docker.internal, not localhost
HINDSIGHT_URL=http://host.docker.internal:8888

# Container settings
CONTAINER_TIMEOUT=1800
IDLE_TIMEOUT=1800
MAX_CONCURRENT_CONTAINERS=3
