# Telegram Bot
TELEGRAM_BOT_TOKEN=your-bot-token-here

# Agent identity (default: Andy)
ASSISTANT_NAME=hex

# Timezone (IANA identifier, e.g. America/Los_Angeles)
# TZ=America/Los_Angeles

# Anthropic API key (used during credential setup, migrated to OneCLI vault)
# ANTHROPIC_API_KEY=sk-ant-...

# GitHub fine-grained PAT
GITHUB_TOKEN=           # GitHub fine-grained PAT — needs: Contents (R/W), Pull requests (R/W), Issues (R/W), Metadata (R)
